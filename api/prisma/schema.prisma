generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Politician {
  id            String     @id @default(uuid())
  name          String
  party         String
  state         String?
  photoUrl      String?
  bundestagId   String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  spending      Spending[]
  
  @@index([party])
  @@index([name])
}

model Spending {
  id            String     @id @default(uuid())
  politicianId  String
  amount        Float
  currency      String     @default("EUR")
  category      String
  date          DateTime
  description   String?
  destination   String?
  sourceUrl     String
  createdAt     DateTime   @default(now())
  
  politician    Politician @relation(fields: [politicianId], references: [id])
  
  @@index([date])
  @@index([category])
  @@index([politicianId])
}

model Category {
  id              String    @id @default(uuid())
  name            String    @unique
  icon            String?
  alertThreshold  Float     @default(500)
  createdAt       DateTime  @default(now())
}

model User {
  id                String   @id @default(uuid())
  telegramId        String?  @unique
  email             String?  @unique
  notificationPrefs Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}